ed['date'])\n","    if 'date' in df_processed.columns and pd.api.types.is_datetime64_any_dtype(df_processed['date']):\n","        df_processed['month'] = df_processed['date'].dt.month\n","        df_processed['dayofweek'] = df_processed['date'].dt.dayofweek\n","        df_processed['dayofyear'] = df_processed['date'].dt.dayofyear\n","        df_processed = df_processed.drop(columns=['date'], errors='ignore')\n","    categorical_cols = ['from', 'to', 'flightType', 'agency']\n","    df_processed = pd.get_dummies(df_processed, columns=[col for col in categorical_cols if col in df_processed.columns], drop_first=True)\n","    df_processed = df_processed.drop(columns=['travelCode', 'userCode', 'price'], errors='ignore')\n","    missing_cols = set(model_features) - set(df_processed.columns)\n","    for c in missing_cols:\n","        df_processed[c] = 0\n","    extra_cols = set(df_processed.columns) - set(model_features)\n","    df_processed = df_processed.drop(columns=list(extra_cols), errors='ignore')\n","    df_processed = df_processed[model_features]\n","    for col in df_processed.select_dtypes(include=['bool']).columns:\n","        df_processed[col] = df_processed[col].astype(int)\n","    return df_processed\n","\n","# --- Helper function to ensure MLflow model is registered for testing ---\n","def ensure_mlflow_model_registered(model_name, stage, global_features):\n","    client = MlflowClient()\n","    try:\n","        # Check if the model exists in the specified stage\n","        latest_versions = client.get_latest_versions(model_name, stages=[stage])\n","        if latest_versions:\n","            print(f\"Model '{model_name}' (Stage: {stage}) already registered. Run ID: {latest_versions[0].run_id}\")\n","            return\n","    except Exception as e:\n","        print(f\"Model '{model_name}' not found in registry (or error: {e}). Registering a dummy model...\")\n","\n","    # If not found, register a dummy model for the test\n","    with mlflow.start_run(run_name=\"Dummy_Test_Model_Registration\") as run:\n","        # Log a dummy model\n","        dummy_model = RandomForestRegressor(n_estimators=1, random_state=42)\n","        dummy_model.fit(pd.DataFrame(np.random.rand(10, len(global_features)), columns=global_features), np.random.rand(10))\n","        mlflow.sklearn.log_model(sk_model=dummy_model, artifact_path=\"random_forest_model\", registered_model_name=model_name)\n","\n","        # Log dummy features artifact\n","        features_artifact_name = 'mlflow_model_features.joblib'\n","        joblib.dump(global_features, features_artifact_name)\n","        mlflow.log_artifact(features_artifact_name, \"model_features\")\n","        os.remove(features_artifact_name)\n","\n","        # Transition to specified stage\n","        client.transition_model_version_stage(name=model_name, version=1, stage=stage)\n","        print(f\"Dummy model '{model_name}' version 1 registered and transitioned to '{stage}' stage.\")\n","\n","# Define a default set of global features for fallback if model_features.joblib is not present\n","global_fallback_features = [\n","    'time', 'distance', 'month', 'dayofweek', 'dayofyear',\n","    'from_Brasilia (DF)', 'from_Campo Grande (MS)', 'from_Florianopolis (SC)',\n","    'from_Natal (RN)', 'from_Recife (PE)', 'from_Rio de Janeiro (RJ)',\n","    'from_Salvador (BH)', 'from_Sao Paulo (SP)',\n","    'to_Brasilia (DF)', 'to_Campo Grande (MS)', 'to_Florianopolis (SC)',\n","    'to_Natal (RN)', 'to_Recife (PE)', 'to_Rio de Janeiro (RJ)',\n","    'to_Salvador (BH)', 'to_Sao Paulo (SP)',\n","    'flightType_firstClass', 'flightType_premium',\n","    'agency_FlyingDrops', 'agency_Rainbow'\n","]\n","\n","# Ensure the model exists in MLflow for payload generation\n","ensure_mlflow_model_registered(MODEL_NAME, MODEL_STAGE, global_fallback_features)\n","\n","# Initialize payload_list outside the try block\n","payload_list = []\n","loaded_model_features = [] # Initialize here as well\n","\n","# --- Global Payload Generation (always create for cURL command) ---\n","try:\n","    # Retrieve model_features from MLflow artifacts to construct a valid payload\n","    client = MlflowClient()\n","    model_version = client.get_latest_versions(MODEL_NAME, stages=[MODEL_STAGE])[0]\n","    run_id = model_version.run_id\n","\n","    # Download the model_features artifact (assuming it was logged as 'model_features/mlflow_model_features.joblib')\n","    # client.download_artifacts returns the local path to the downloaded file\n","    downloaded_features_full_path = client.download_artifacts(\n","        run_id=run_id,\n","        path=\"model_features/mlflow_model_features.joblib\", # Corrected: 'path' instead of 'artifact_path'\n","        dst_path=\".\" # Download to current directory\n","    )\n","    loaded_model_features = joblib.load(downloaded_features_full_path)\n","    os.remove(downloaded_features_full_path) # Clean up temporary file\n","    print(f\"Successfully loaded {len(loaded_model_features)} model features from MLflow artifacts (Run ID: {run_id}).\")\n","\n","    sample_raw_data = pd.DataFrame([\n","        {\n","            'travelCode': 100000,\n","            'userCode': 67890,\n","            'from': 'Rio de Janeiro (RJ)',\n","            'to': 'Sao Paulo (SP)',\n","            'flightType': 'premium',\n","            'price': np.nan, # To be predicted\n","            'time': 1.1,\n","            'distance': 450.5,\n","            'agency': 'CloudFy',\n","            'date': '2024-09-01'\n","        },\n","        {\n","            'travelCode': 100001,\n","            'userCode': 67891,\n","            'from': 'Recife (PE)',\n","            'to': 'Florianopolis (SC)',\n","            'flightType': 'firstClass',\n","            'price': np.nan, # To be predicted\n","            'time': 1.76,\n","            'distance': 676.53,\n","            'agency': 'FlyingDrops',\n","            'date': '2024-09-26'\n","        }\n","    ])\n","\n","    preprocessed_sample_for_api = preprocess_flight_data_for_api_test(sample_raw_data.copy(), loaded_model_features)\n","\n","    for _, row in preprocessed_sample_for_api.iterrows():\n","        row_dict = row.to_dict()\n","        # Convert numpy bool_ to Python bool for JSON serialization\n","        for key, value in row_dict.items():\n","            if isinstance(value, np.bool_):\n","                row_dict[key] = bool(value)\n","        payload_list.append(row_dict)\n","\n","except Exception as e:\n","    print(f\"Error preparing payload from MLflow: {e}\")\n","    # payload_list already initialized as []\n","    # loaded_model_features already initialized as []\n","\n","# --- Main API Test Logic ---\n","if YOUR_K8S_EXTERNAL_IP == \"YOUR_K8S_EXTERNAL_IP\":\n","    print(\"Please replace 'YOUR_K8S_EXTERNAL_IP' with the actual external IP of your Kubernetes service.\")\n","    print(\"You can get it by running: kubectl get services flight-predictor-service\")\n","else:\n","    print(\"--- Testing Kubernetes Deployed API with MLflow Model ---\\n\")\n","\n","    try:\n","        api_url = f\"http://{YOUR_K8S_EXTERNAL_IP}/predict\"\n","        headers = {'Content-Type': 'application/json'}\n","\n","        print(f\"Sending POST request to: {api_url}\")\n","        print(\"Sample Payload (first entry): \")\n","        # Check if payload_list is empty before trying to access index 0\n","        if payload_list:\n","            print(json.dumps(payload_list[0], indent=2))\n","        else:\n","            print(\"Payload list is empty, cannot display first entry.\")\n","\n","        response = requests.post(api_url, headers=headers, data=json.dumps(payload_list), timeout=20)\n","        response.raise_for_status() # Raise an HTTPError for bad responses (4xx or 5xx)\n","        predictions = response.json()\n","\n","        print(f\"\\nAPI Response: {predictions}\")\n","        print(f\"Predicted Prices: {', '.join([f'{p:.2f}' for p in predictions['prediction']])}\")\n","        print(\"API successfully returned predictions using the MLflow model!\")\n","\n","    except requests.exceptions.ConnectionError as e:\n","        print(f\"\\nError: Could not connect to the API. Make sure the Kubernetes service is running and the EXTERNAL-IP is correct. {e}\")\n","    except requests.exceptions.Timeout:\n","        print(f\"\\nError: Request timed out. The API might be slow to respond or unreachable.\")\n","    except requests.exceptions.HTTPError as e:\n","        print(f\"\\nHTTP Error: {e.response.status_code} - {e.response.text}\")\n","    except Exception as e:\n","        print(f\"\\nAn unexpected error occurred: {e}\")\n","\n","print(\"\\n--- cURL Command Example ---\")\n","# Generate a cURL command using the same payload\n","curl_payload = json.dumps(payload_list)\n","curl_command = f\"curl -X POST -H \\\"Content-Type: application/json\\\" -d '{curl_payload}' http://{YOUR_K8S_EXTERNAL_IP}/predict\"\n","print(\"Please run the following command in your terminal after replacing 'YOUR_K8S_EXTERNAL_IP':\")\n","print(curl_command)\n"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Model 'FlightPricePredictor' (Stage: Staging) already registered. Run ID: f4d544a911b248d69b8c5ca0e7b80912\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-3780336618.py:55: FutureWarning: ``mlflow.tracking.client.MlflowClient.get_latest_versions`` is deprecated since 2.9.0. Model registry stages will be removed in a future major release. To learn more about the deprecation of model registry stages, see our migration guide here: https://mlflow.org/docs/latest/model-registry.html#migrating-from-stages\n","  latest_versions = client.get_latest_versions(model_name, stages=[stage])\n","/tmp/ipython-input-3780336618.py:103: FutureWarning: ``mlflow.tracking.client.MlflowClient.get_latest_versions`` is deprecated since 2.9.0. Model registry stages will be removed in a future major release. To learn more about the deprecation of mo